meta {
  name: Update User (Super Admin)
  type: http
  seq: 7
}

patch {
  url: {{baseUrl}}/users/{{userId}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "role": "ADMIN",
    "status": "ACTIVE",
    "firstName": "John",
    "lastName": "Smith",
    "displayName": "Dr. Smith",
    "jobTitle": "Psychiatrist",
    "timezone": "America/Toronto"
  }
}
