meta {
  name: List Reminders
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/reminders
  body: none
  auth: none
}

query {
  page: 1
  pageSize: 20
  orderBy: sendAt
  order: desc
  ~status: PENDING
  ~patientId: {{patientId}}
  ~dateFrom: 2025-01-01T00:00:00.000Z
  ~dateTo: 2025-12-31T23:59:59.000Z
  ~search: Maria
}
