meta {
  name: Send SMS
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/notify/sms
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "to": "+15551234567",
    "body": "Hi Maria, this is a reminder for your appointment on June 15 at 10:00 AM. Reply STOP to unsubscribe.",
    "patientId": "{{patientId}}"
  }
}
