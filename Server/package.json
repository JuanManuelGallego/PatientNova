{
  "name": "PatientNova_Server",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "build": "prisma generate && tsup",
    "typecheck": "tsc --noEmit",
    "start": "prisma migrate deploy && npm run db:seed-admin && node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed-admin": "tsx src/prisma/seedAdmin.ts",
    "db:migrate-reminders": "tsx src/scripts/migratePendingReminders.ts",
    "db:format": "npx prisma db push",
    "db:wipe": "npx prisma migrate reset --force --skip-seed"
  },
  "author": "Juan Manuel Gallego",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.5",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^4.1.10",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@google-apps/meet": "^0.7.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.6.0",
    "pg": "^8.22.0",
    "pg-boss": "^12.26.0",
    "pino": "^10.3.1",
    "twilio": "^6.0.2",
    "zod": "^4.4.3"
  }
}
