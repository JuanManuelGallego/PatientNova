# Integration test environment — loads via test/integration/setup.ts (vitest project: integration).
# Mirrors the env block from .github/workflows/ci.yml (the CI workflow supplies these vars
# directly and does NOT load this file — keep the two in sync when adding requireEnv vars).
# All external services are mocked at the module boundary in tests, so dummy values are fine here.
# IMPORTANT: DATABASE_URL must contain "test" (enforced by the test DB guard).
# Local test DB runs on 127.0.0.1:5433 (docker-compose.test.yml); CI uses localhost:5432.

NODE_ENV=test
PORT=3001
LOG_LEVEL=info

# Test Postgres (docker-compose.test.yml -> port 5433)
DATABASE_URL="postgresql://test:test@127.0.0.1:5433/patientnova_test?schema=public"

# Encryption (32-byte hex). Leave empty in test; config falls back to "" outside production.
ENCRYPTION_KEY=

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# Auth
AUTH_SECRET=dummy-auth-secret-for-integration-tests
BCRYPT_ROUNDS=4
COOKIE_DOMAIN=localhost

# Account lockout
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION_MS=900000

# Defaults
DEFAULT_TIMEZONE=America/Bogota
DEFAULT_CURRENCY=COP

# Scheduler — must stay off so background workers don't poll the shared test DB
ENABLE_SCHEDULER=false
DAILY_REMINDER_HOUR=18
CRON_SCHEDULE="* * * * *"

# Twilio (dummy — mocked at twilioClient boundary)
TWILIO_ACCOUNT_SID=dummySID
TWILIO_AUTH_TOKEN=dummyToken
TWILIO_WHATSAPP_FROM=dummyNumber
TWILIO_SMS_FROM=dummySMSNumber
TWILIO_WEBHOOK_BASE_URL=https://example.com/twilio
TWILIO_WHATSAPP_USER_REMINDER_SID=dummyReminderSid
TWILIO_WHATSAPP_USER_REMINDER_2_APPT_SID=dummyReminder2Sid
TWILIO_WHATSAPP_USER_REMINDER_3_APPT_SID=dummyReminder3Sid
TWILIO_WHATSAPP_USER_REMINDER_4_APPT_SID=dummyReminder4Sid
TWILIO_WHATSAPP_USER_REMINDER_5_APPT_SID=dummyReminder5Sid
TWILIO_WHATSAPP_USER_REMINDER_6_APPT_SID=dummyReminder6Sid
TWILIO_WHATSAPP_USER_APPOINTMENT_STATUS_UPDATE_SID=dummyStatusSid
TWILIO_WHATSAPP_PATIENT_APPOINTMENT_MEETING_LINK_SID=dummyMeetingLinkSid

# Google (dummy — mocked at google-meet.service boundary)
GOOGLE_CLIENT_ID=dummy-google-client-id
GOOGLE_CLIENT_SECRET=dummy-google-client-secret
GOOGLE_REFRESH_TOKEN=dummy-google-refresh-token

# Seed
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=dummy-admin-password

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]
