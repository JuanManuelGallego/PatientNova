generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Patient ──────────────────────────────────────────────────────────────────

model Patient {
  id             String        @id @default(uuid()) @db.Uuid
  name           String        @db.VarChar(100)
  lastName       String        @db.VarChar(100)
  fullName       String?       @db.VarChar(200)
  whatsappNumber String?       @db.VarChar(20)
  smsNumber      String?       @db.VarChar(20)
  email          String        @unique @db.VarChar(255)
  status         PatientStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  appointments   Appointment[]
  reminders      Reminder[] @relation("PatientReminders")

  @@map("patients")
}

enum PatientStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

// ─── Reminder ─────────────────────────────────────────────────────────────────

model Reminder {
  channel     Channel
  contentSid  String?        @db.VarChar(100)
  contentVariables Json?
  createdAt   DateTime       @default(now())
  error       String?
  id          String         @id @default(uuid()) @db.Uuid
  messageId   String?        @db.VarChar(100)
  mode        ReminderMode
  patientId   String?        @db.Uuid
  scheduledAt DateTime?
  sentAt      DateTime?
  status      ReminderStatus @default(PENDING)
  to          String         @db.VarChar(30)
  updatedAt   DateTime       @updatedAt

  appointments Appointment[]
  patient      Patient?       @relation("PatientReminders", fields: [patientId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([scheduledAt])
  @@index([patientId])
  @@map("reminders")
}

enum Channel {
  WHATSAPP
  SMS
  EMAIL
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum ReminderMode {
  IMMEDIATE
  SCHEDULED
}

// ─── Appointment ──────────────────────────────────────────────────────────────

model Appointment {
  createdAt  DateTime          @default(now())
  date       DateTime          @default(now())
  duration   String            @db.VarChar(20)   // e.g. "30 min"
  id         String            @id @default(uuid()) @db.Uuid
  location   String            @db.VarChar(255)
  meetingUrl String?           @db.VarChar(500)
  notes      String?            @db.VarChar(500)
  patientId  String            @db.Uuid
  payed      Boolean           @default(false)
  price      String            @db.VarChar(20)   // e.g. "150.000"
  reminderId String?           @db.Uuid
  status     AppointmentStatus @default(SCHEDULED)
  type       String            @db.VarChar(120)
  updatedAt  DateTime          @updatedAt

  patient    Patient           @relation(fields: [patientId],  references: [id], onDelete: Cascade)
  reminder   Reminder?         @relation(fields: [reminderId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([date])
  @@index([status])
  @@map("appointments")
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}
