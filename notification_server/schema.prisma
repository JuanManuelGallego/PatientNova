generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Patient ──────────────────────────────────────────────────────────────────

model Patient {
  id             String        @id @default(uuid()) @db.Uuid

  name           String        @db.VarChar(100)
  lastName       String        @db.VarChar(100)

  whatsappNumber String?       @db.VarChar(20)
  smsNumber      String?       @db.VarChar(20)
  email          String?        @unique @db.VarChar(255)

  dateOfBirth    DateTime?
  notes          String?       @db.VarChar(500)

  status         PatientStatus @default(ACTIVE)
  archivedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  appointments   Appointment[] @relation("PatientAppointments")
  reminders      Reminder[]    @relation("PatientReminders")

  @@index([name])
  @@index([lastName])
  @@index([status])
  @@map("patients")
}

enum PatientStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

// ─── Reminder ─────────────────────────────────────────────────────────────────

model Reminder {
  id                String         @id @default(uuid()) @db.Uuid

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  
  channel           Channel
  to                String         @db.VarChar(30)

  contentSid        String?        @db.VarChar(100)
  contentVariables  Json?
  
  status            ReminderStatus @default(PENDING)
  error             String?
  
  sendMode          ReminderMode
  sendAt            DateTime?
  sentAt            DateTime?
  messageId         String?        @db.VarChar(100)

  appointmentId     String?        @unique @db.Uuid
  patientId         String?        @db.Uuid

  appointment       Appointment?   @relation("AppointmentReminder", fields: [appointmentId], references: [id], onDelete: Cascade)
  patient           Patient?       @relation("PatientReminders", fields: [patientId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([sendAt])
  @@index([patientId])
  @@index([status, sendAt])
  @@map("reminders")
}

enum Channel {
  WHATSAPP
  SMS
  EMAIL
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum ReminderMode {
  IMMEDIATE
  SCHEDULED
}

// ─── Appointment ──────────────────────────────────────────────────────────────

model Appointment {
  id            String            @id @default(uuid()) @db.Uuid

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  startAt       DateTime
  endAt         DateTime
  timezone      String?           @db.VarChar(50)@default("CST")

  price         Int
  currency      String?           @default("COP") @db.Char(3)
  paid          Boolean           @default(false)

  location      String            @db.VarChar(255)
  meetingUrl    String?           @db.VarChar(500)
  notes         String?           @db.VarChar(500)
  type          String

  status        AppointmentStatus @default(SCHEDULED)
  confirmedAt   DateTime?
  cancelledAt   DateTime?
  completedAt   DateTime?

  patientId     String            @db.Uuid
  reminderId    String?           @db.Uuid
  
  patient       Patient           @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  reminder      Reminder?         @relation("AppointmentReminder")

  @@index([patientId])
  @@index([startAt])
  @@index([status])
  @@index([startAt, status])
  @@map("appointments")
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}
