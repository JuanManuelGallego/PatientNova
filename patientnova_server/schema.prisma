generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Patient ──────────────────────────────────────────────────────────────────

model Patient {
  id             String        @id @default(uuid()) @db.Uuid

  name           String        @db.VarChar(100)
  lastName       String        @db.VarChar(100)

  whatsappNumber String?       @db.VarChar(20)
  smsNumber      String?       @db.VarChar(20)
  email          String?       @db.VarChar(255)

  notes                  String?           @db.Text
  appointmentTypeId      String?           @db.Uuid

  status         PatientStatus @default(ACTIVE)
  isDeleted      Boolean       @default(false)
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  userId         String
  user           User              @relation(fields: [userId], references: [id])
  appointmentType AppointmentType? @relation(fields: [appointmentTypeId], references: [id], onDelete: SetNull)

  appointments   Appointment[] @relation("PatientAppointments")
  reminders      Reminder[]    @relation("PatientReminders")
  medicalRecord  MedicalRecord?

  @@unique([userId, email])
  @@index([userId])
  @@index([userId, status])
  @@index([userId, isDeleted])
  @@index([name])
  @@index([lastName])
  @@index([status])
  @@map("patients")
}

enum PatientStatus {
  ACTIVE
  INACTIVE
}

// ─── Reminder ─────────────────────────────────────────────────────────────────

model Reminder {
  id                String         @id @default(uuid()) @db.Uuid

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  isDeleted         Boolean        @default(false)
  deletedAt         DateTime?

  channel           Channel
  to                String         @db.VarChar(30)

  contentSid        String?        @db.VarChar(100)
  contentVariables  Json?
  body              String?        @db.Text

  status            ReminderStatus @default(PENDING)
  error             String?

  sendMode          ReminderMode
  sendAt            DateTime
  sentAt            DateTime?
  messageId         String?        @db.VarChar(100)

  appointmentId     String?        @unique @db.Uuid
  patientId         String         @db.Uuid
  userId            String

  appointment       Appointment?   @relation("AppointmentReminder", fields: [appointmentId], references: [id], onDelete: Cascade)
  patient           Patient        @relation("PatientReminders", fields: [patientId], references: [id], onDelete: Cascade)
  user              User           @relation("UserReminders", fields: [userId], references: [id])

  @@index([status])
  @@index([sendAt])
  @@index([patientId])
  @@index([userId])
  @@index([status, sendAt])
  @@index([userId, status])
  @@map("reminders")
}

enum Channel {
  WHATSAPP
  SMS
  EMAIL
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
  QUEUED
}

enum ReminderMode {
  IMMEDIATE
  SCHEDULED
}

// ─── Appointment ──────────────────────────────────────────────────────────────

model Appointment {
  id            String            @id @default(uuid()) @db.Uuid

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  startAt       DateTime
  endAt         DateTime
  timezone      String            @db.VarChar(50)@default("CST")

  price         Int
  currency      String            @default("COP") @db.Char(3)
  paid          Boolean           @default(false)

  meetingUrl    String?           @db.VarChar(500)
  notes         String?           @db.Text

  status        AppointmentStatus @default(SCHEDULED)
  confirmedAt   DateTime?
  cancelledAt   DateTime?
  completedAt   DateTime?
  isDeleted     Boolean           @default(false)
  deletedAt     DateTime?

  patientId     String            @db.Uuid
  userId        String
  reminderId    String?           @db.Uuid
  locationId    String?           @db.Uuid
  typeId        String?           @db.Uuid

  patient             Patient              @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  user                User                 @relation("UserAppointments", fields: [userId], references: [id])
  reminder            Reminder?            @relation("AppointmentReminder")
  appointmentLocation AppointmentLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  appointmentType     AppointmentType?     @relation(fields: [typeId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([userId])
  @@index([startAt])
  @@index([status])
  @@index([startAt, status])
  @@index([userId, status])
  @@index([userId, startAt])
  @@index([userId, isDeleted])
  @@index([locationId])
  @@index([typeId])
  @@map("appointments")
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ─── User (Admin Accounts) ────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email          String      @unique
  passwordHash   String

  role           AdminRole   @default(VIEWER)
  status         AdminStatus @default(PENDING)

  firstName      String?
  lastName       String?
  displayName    String?
  avatar         String?
  jobTitle       String?
  logo           String?
  altLogo        String?

  phoneNumber    String?  @db.VarChar(20)
  whatsappNumber String?  @db.VarChar(20)

  reminderActive        Boolean  @default(true)
  reminderChannel       Channel  @default(WHATSAPP)
  lastDailyReminderDate DateTime?

  bankName      String?
  accountNumber String?
  nationalId    String?
  bankingKey    String?

  timezone             String    @default("America/Bogota") @db.VarChar(50)

  lastPasswordChange   DateTime?
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime?
  lastLoginAt          DateTime?
  lastLoginIp          String?
  refreshTokenVersion  Int       @default(0)

  deletedAt      DateTime?
  isDeleted      Boolean  @default(false)

  patients              Patient[]
  appointments          Appointment[] @relation("UserAppointments")
  reminders             Reminder[]    @relation("UserReminders")
  appointmentLocations  AppointmentLocation[]
  appointmentTypes      AppointmentType[]
  consentDocument       Document?

  @@index([email])
  @@index([status])
  @@index([isDeleted])
  @@map("users")
}

// ─── Appointment Location ────────────────────────────────────────────────────

model AppointmentLocation {
  id           String   @id @default(uuid()) @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  name         String   @db.VarChar(100)
  address      String?  @db.VarChar(255)
  instructions String?  @db.VarChar(500)
  color        String?  @db.VarChar(20)
  defaultPrice Int?
  isVirtual    Boolean  @default(false)
  isActive     Boolean  @default(true)
  isDeleted    Boolean  @default(false)
  deletedAt    DateTime?

  userId       String
  user         User          @relation(fields: [userId], references: [id])
  appointments Appointment[]

  @@unique([userId, name])
  @@index([userId])
  @@map("appointment_locations")
}

// ─── Appointment Type ────────────────────────────────────────────────────────

model AppointmentType {
  id              String   @id @default(uuid()) @db.Uuid
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  name            String   @db.VarChar(100)
  description     String?  @db.VarChar(500)
  defaultDuration Int      @default(60)
  defaultPrice    Int?
  color           String?  @db.VarChar(20)
  isActive        Boolean  @default(true)
  isDeleted       Boolean  @default(false)
  deletedAt       DateTime?

  userId          String
  user            User          @relation(fields: [userId], references: [id])
  appointments    Appointment[]
  patients        Patient[]

  @@unique([userId, name])
  @@index([userId])
  @@map("appointment_types")
}

enum AdminRole {
  VIEWER
  ADMIN
  SUPER_ADMIN
}

enum AdminStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum SubsistemaType {
  CONYUGAL
  PARENTAL
  FILIAL
  FRATERNO
}

enum EstadoRelacion {
  FUNCIONAL
  DISFUNCIONAL
  DISFUNCIONAL_COMUNICACION
  DISFUNCIONAL_JERARQUIA
  DISFUNCIONAL_LIMITES
}

// ─── Medical Record ───────────────────────────────────────────────────────────

model MedicalRecord {
  id         String   @id @default(uuid()) @db.Uuid

  // Personal data
  name                String?
  nationalId          String?
  sex                 String?
  age                 String?
  birthDate           DateTime?
  birthPlace          String?

  // Clinical history
  consultationReason        String? @db.Text
  earlyDevelopment          String? @db.Text
  schoolAndWork             String? @db.Text
  lifestyleHabits           String? @db.Text
  traumaticEvents           String? @db.Text
  emotionalConsiderations   String? @db.Text
  physicalConsiderations    String? @db.Text
  mentalHistory             String? @db.Text
  objective                 String? @db.Text
  familyObservations        String? @db.Text

  // Family fields
  isFamily      Boolean @default(false)
  familyType    String? @db.Text
  lifecycle     String? @db.Text
  genogram      String? @db.Text
  ressources    String? @db.Text
  difficulties  String? @db.Text
  communication String? @db.Text
  rule          String? @db.Text
  limits        String? @db.Text
  familyContext String? @db.Text
  expectations  String? @db.Text
  flexibility   String? @db.Text

  // Relations
  familyMembers      FamilyMember[]
  evolutionNotes     EvolutionNote[]
  documents          MedicalDocument[]
  subsystemRelations SubsystemRelation[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isDeleted  Boolean  @default(false)
  deletedAt  DateTime?

  patientId  String   @unique @db.Uuid
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([isDeleted])
  @@map("medical_records")
}

// ─── Subsystem relations ──────────────────────────────────────────────────────

model SubsystemRelation {
  id              String         @id @default(uuid()) @db.Uuid

  medicalRecordId String         @db.Uuid
  medicalRecord   MedicalRecord  @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)

  subsistema      SubsistemaType
  estado          EstadoRelacion
  observacion     String?        @db.Text

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // One estado per subsistema per record
  @@unique([medicalRecordId, subsistema, estado])
  @@index([medicalRecordId])
  @@map("subsystem_relations")
}

// ─── Family Member ────────────────────────────────────────────────────────────

model FamilyMember {
  id           String        @id @default(uuid()) @db.Uuid

  name         String?
  sex          Sex?
  age          String?
  relationship Relationship?
  relation     String?        @db.Text

  medicalRecordId String        @db.Uuid
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)

  @@index([medicalRecordId])
  @@map("family_members")
}

// ─── Evolution Note ───────────────────────────────────────────────────────────

model EvolutionNote {
  id   String @id @default(uuid()) @db.Uuid

  date DateTime
  text String?  @db.Text

  medicalRecordId String        @db.Uuid
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)

  @@index([medicalRecordId])
  @@map("evolution_notes")
}

// ─── Documents ───────────────────────────────────────────────────────────
model Document {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User @relation(fields:[userId], references:[id], onDelete: Cascade)
  name      String
  content   Bytes
  mimeType  String  @default("application/pdf")
  sizeBytes Int?
  checksum  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("documents")
}

enum Sex {
  MALE
  FEMALE
  OTHER
}

enum Relationship {
  FATHER
  MOTHER
  SIBLING
  SON
  DAUGHTER
  SPOUSE
  GRANDFATHER
  GRANDMOTHER
  OTHER
}

// ─── Medical Document ───────────────────────────────────────────────────────────

model MedicalDocument {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  mimeType        String
  sizeBytes       Int
  data            String   @db.Text   // base64 data-URL
  uploadedAt      DateTime @default(now())

  medicalRecordId String        @db.Uuid
  medicalRecord   MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)

  @@index([medicalRecordId])
  @@map("medical_documents")
}