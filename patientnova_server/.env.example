# ──────────────────────────────────────────────
#  Twilio Notification Service — Environment
#  Copy to .env and fill in real values.
#  NEVER commit the actual .env to source control.
# ──────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info            # trace | debug | info | warn | error

# Twilio credentials — get from console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twillo Whatsapp SIDs — set up in Twilio console
TWILIO_WHATSAPP_USER_REMINDER_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_USER_REMINDER_2_APPT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_USER_REMINDER_3_APPT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_USER_REMINDER_4_APPT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_USER_REMINDER_5_APPT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_USER_REMINDER_6_APPT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Whatsapp Webhook
TWILIO_WEBHOOK_BASE_URL=https://send-jigsaw-rack.ngrok-free.dev/webhooks/twilio

# Sender numbers
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Twilio sandbox or approved number
TWILIO_SMS_FROM=+15551234567                  # Your Twilio SMS number

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000   # 1 minute window
RATE_LIMIT_MAX=30             # max requests per window per IP

# PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/notificationservice?schema=public"

# Authentication — shared secret used for JWT signing
# Generate with: openssl rand -hex 64
AUTH_SECRET=your-secure-random-string-at-least-32-chars
BCRYPT_ROUNDS=12

# Seed
ADMIN_EMAIL="admin@patientnova.net"
ADMIN_PASSWORD="admin"

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001","https://app.patientnova.net","https://patientnova.net"]


# Twilio Webhook — public base URL this server is reachable at (used for signature validation)
# e.g. https://your-server.com  or  https://abc123.ngrok.io  (no trailing slash)
TWILIO_WEBHOOK_BASE_URL=https://your-server.com

# Account lockout settings
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION_MS=900000  # 15 minutes